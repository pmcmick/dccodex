FROM ubuntu:24.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    bash \
    build-essential \
    ca-certificates \
    clang \
    cmake \
    curl \
    git \
    libbz2-dev \
    libcap-dev \
    liblzma-dev \
    libsqlite3-dev \
    libssl-dev \
    libzstd-dev \
    lld \
    musl-tools \
    perl \
    pkg-config \
    sudo \
    xz-utils && \
    rm -rf /var/lib/apt/lists/*

RUN arch="$(dpkg --print-architecture)" && \
    case "${arch}" in \
      amd64) zig_arch="x86_64" ;; \
      arm64) zig_arch="aarch64" ;; \
      *) echo "Unsupported architecture: ${arch}" >&2; exit 1 ;; \
    esac && \
    zig_version="0.14.0" && \
    curl -fsSL "https://ziglang.org/download/${zig_version}/zig-linux-${zig_arch}-${zig_version}.tar.xz" -o /tmp/zig.tar.xz && \
    mkdir -p /opt/zig && \
    tar -xJf /tmp/zig.tar.xz -C /opt/zig --strip-components=1 && \
    ln -sf /opt/zig/zig /usr/local/bin/zig && \
    rm -f /tmp/zig.tar.xz

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal --default-toolchain 1.93.0

ENV PATH="/root/.cargo/bin:${PATH}"
WORKDIR /workspace
